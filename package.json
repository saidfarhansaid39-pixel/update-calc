{
  "name": "calc-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node packages/calculator-registry/scripts/build.mjs && next dev",
    "build": "node packages/calculator-registry/scripts/build.mjs && npm run build:search-index && npx prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "build:search-index": "node --experimental-strip-types scripts/build-search-index.mjs",
    "typecheck": "tsc --noEmit",
    "analyze": "ANALYZE=true next build",
    "test": "vitest run",
    "content:build": "velite build",
    "content:dev": "velite dev --watch",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "translate:overrides": "node scripts/translate-overrides.mjs"
  },
  "dependencies": {
    "@calcuniverse/calculator-registry": "workspace:*",
    "@calcuniverse/formulas": "workspace:*",
    "@hookform/resolvers": "^3.3.4",
    "@prisma/client": "^5.14.0",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "framer-motion": "^12.39.0",
    "lucide-react": "^0.300.0",
    "minisearch": "^7.2.0",
    "next": "^16.2.6",
    "next-intl": "^4.13.0",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.12.1",
    "@eslint/compat": "^2.1.0",
    "@next/bundle-analyzer": "^16.2.9",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "latest",
    "postcss": "^8",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.3.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "velite": "^0.4.0",
    "vitest": "^1.6.1"
  }
}
